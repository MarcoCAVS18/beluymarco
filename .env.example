VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Email de Google habilitado para entrar a la app (debe coincidir con el
# hardcodeado en firestore.rules). Opcional: por defecto es marcopiermatei1@gmail.com
VITE_ALLOWED_EMAIL=marcopiermatei1@gmail.com

# Netlify Functions - Gmail OAuth (se cargan directo en las env vars de Netlify,
# no son necesarias para el frontend/Vite). Ver netlify/functions/README.md.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/gmail-oauth-exchange
GOOGLE_REFRESH_TOKEN=your_refresh_token_obtained_once
