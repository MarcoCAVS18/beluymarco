rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write access to all collections
    // WARNING: This is open to anyone - consider adding Firebase Auth later
    match /{document=**} {
      allow read, write: if true;
    }

    // Specific rules per collection (commented out - uncomment when you add Auth)

    // Wineries collection
    // match /wineries/{wineryId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }

    // Housekeeping collection
    // match /housekeeping/{housekeepingId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }

    // Templates collection
    // match /templates/{templateId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }

    // Config collection
    // match /config/{configId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }
  }
}
