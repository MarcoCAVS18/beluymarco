rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Acceso restringido: solo la cuenta de Google autorizada (uso personal,
    // un solo usuario) puede leer/escribir cualquier colección.
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'marcopiermatei1@gmail.com';
    }
  }
}
